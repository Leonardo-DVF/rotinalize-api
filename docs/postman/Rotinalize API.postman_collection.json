            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.environment.set('userId', json.id);",
                  "  pm.collectionVariables.set('userId', json.id);",
